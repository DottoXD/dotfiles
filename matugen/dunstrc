[global]
    monitor = 0
    follow = none
    
    width = 450
    height = (0, 300)
    origin = bottom-center
    offset = (0, 75) 
    corner_radius = 28
    frame_width = 2
    gap_size = 10
    
    font = Google Sans Flex 11
    padding = 20
    horizontal_padding = 20
    text_icon_padding = 15
    
    alignment = left
    vertical_alignment = center
    
    icon_position = left
    min_icon_size = 48
    max_icon_size = 64
    icon_corner_radius = 16

    progress_bar = true
    progress_bar_height = 12
    progress_bar_frame_width = 0
    progress_bar_corner_radius = 100
    progress_bar_min_width = 300
    progress_bar_max_width = 360

    format = "<b>%s</b>\n%b"

[urgency_low]
    background = "{{colors.surface_container.default.hex}}"
    foreground = "{{colors.on_surface.default.hex}}"
    frame_color = "{{colors.outline_variant.default.hex}}"
    highlight = "{{colors.primary.default.hex}}"
    timeout = 4

[urgency_normal]
    background = "{{colors.surface_container.default.hex}}"
    foreground = "{{colors.on_surface.default.hex}}"
    frame_color = "{{colors.primary.default.hex}}"
    highlight = "{{colors.primary.default.hex}}"
    timeout = 8

[urgency_critical]
    background = "{{colors.error_container.default.hex}}"
    foreground = "{{colors.on_error_container.default.hex}}"
    frame_color = "{{colors.error.default.hex}}"
    highlight = "{{colors.error.default.hex}}"
    timeout = 0
