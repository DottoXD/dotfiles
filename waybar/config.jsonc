// -*- mode: jsonc -*-
{
    "height": 26,
    "margin-top": 6,
    "margin-left": 8,
    "margin-right": 8,
    "spacing": 8,
    "gtk-layer-shell": true,
    "modules-left": [
        "hyprland/window"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "power-profiles-daemon",
        "pulseaudio",
        "network",
        "battery",
        "clock",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "format": "{name}",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
	"sort-by-number": true
    },
    "hyprland/window": {
        "format": "{}",
        "rotate": 0,
        "separate-outputs": true,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹  $1",
            "(.*) â€” Nautilus": "َ°‰‹  $1",
	    "(.*) - Chromium": "َ°ٹ¯  $1",
	    "(.*) - Code - OSS": "َ°¨‍  $1",
	    "~": "َ°„›  Terminal",
            "": "ï’ˆ  N/A"
        },
        "max-length": 60
    },
    "clock": {
        "timezone": "Europe/Rome",
        "format": "{:%H:%M آ· %a %d}",
	"tooltip": false
    },
    "battery": {
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ï—§",
        "format-plugged": "{capacity}% ï‡¦",
        "format-icons": ["َ°‚ژ", "َ°پ»", "َ°پ½", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°پ¹"],
	"tooltip-format": "{time}"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "{profile} - driver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ïƒ§",
            "performance": "ïƒ§",
            "balanced": "ï‰ژ",
            "power-saver": "ïپ¬"
        }
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%)  َ°¤¨",
        "format-ethernet": "{ipaddr}/{cidr}  ï‍–",
        "tooltip-format": "{ifname} - {gwaddr}  ï‍–",
        "format-linked": "{ifname}  ï‍–",
        "format-disconnected": "َ°¤­",
        "interval": 5
    },
    "pulseaudio": {
        "scroll-step": 1,
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}",
        "format-bluetooth-muted": "ïڑ©  {icon}",
        "format-muted": "ïڑ© ",
        "format-source": "{volume}% ï„°",
        "format-source-muted": "ï„±",
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï–گ",
            "headset": "ï–گ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        }
    },
    "custom/power": {
        "format" : "ï€‘",
	"tooltip": false,
	"menu": "on-click",
	"menu-file": "$HOME/.config/waybar/power_menu.xml",
	"menu-actions": {
	    "shutdown": "systemctl poweroff",
	    "reboot": "systemctl reboot",
	    "suspend": "systemctl suspend",
	    "hibernate": "systemctl hibernate"
	}
    }
}
