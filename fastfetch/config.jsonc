{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "display": {
    "separator": " \u203a ",
    "key": { "width": 18 },
    "color": {
      "keys": "38;2;132;210;230",
      "title": "38;2;132;210;230"
    }
  },
  "logo": {
    "type": "auto",
    "color": {
      "1": "38;2;178;203;210",
      "2": "38;2;178;203;210"
    }
  },
  "modules": [
    "break",
    {
      "type": "title",
      "format": "{user-name}@{host-name}",
      "color": {
        "user": "38;2;132;210;230",
        "at": "37",
        "host": "38;2;178;203;210"
      }
    },
    {
      "type": "separator",
      "string": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "outputColor": "38;2;63;72;75"
    },
    {
      "type": "os",
      "key": " OS",
      "keyColor": "38;2;178;203;210"
    },
    {
      "type": "kernel",
      "key": " Kernel",
      "keyColor": "38;2;178;203;210"
    },
    {
      "type": "uptime",
      "key": " Uptime",
      "keyColor": "38;2;178;203;210"
    },
    {
      "type": "shell",
      "key": " Shell",
      "keyColor": "38;2;178;203;210"
    },
    {
      "type": "wm",
      "key": " WM",
      "keyColor": "38;2;178;203;210"
    },
    {
      "type": "terminal",
      "key": " Terminal",
      "keyColor": "38;2;178;203;210"
    },
    {
      "type": "cpu",
      "key": " CPU",
      "keyColor": "38;2;178;203;210",
      "temp": true
    },
    {
      "type": "gpu",
      "key": "󰾲 GPU",
      "keyColor": "38;2;178;203;210",
      "driverSpecific": false,
      "detectionMethod": "pci",
      "temp": true
    },
    {
      "type": "memory",
      "key": "󰍛 Memory",
      "keyColor": "38;2;178;203;210",
      "percent": { "type": 0 }
    },
    {
      "type": "swap",
      "percent": {
        "green": 50,
        "yellow": 80,
        "type": 0
      },
      "key": "󰓡 Swap",
      "keyColor": "38;2;178;203;210",
      "separate": false
    },
    {
      "type": "disk",
      "key": " Disk",
      "keyColor": "38;2;178;203;210",
      "showRegular": true,
      "showExternal": false,
      "showHidden": false,
      "showSubvolumes": false,
      "showReadOnly": false,
      "showUnknown": false,
      "folders": ["/", "/home"],
      "hideFolders": "/efi:/boot:/boot/*",
      "hideFS": "",
      "useAvailable": false,
      "percent": {
        "green": 50,
        "yellow": 80,
        "type": 0
      }
    },
    {
      "type": "battery",
      "key": " Battery",
      "keyColor": "38;2;178;203;210",
      "temp": true
    },
    {
      "type": "separator",
      "string": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "outputColor": "38;2;63;72;75"
    },
    {
      "type": "colors",
      "key": " ",
      "symbol": "circle",
      "block": { "width": 2 }
    }
  ]
}
